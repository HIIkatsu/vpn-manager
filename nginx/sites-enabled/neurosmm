server {
    server_name neurosmmai.ru www.neurosmmai.ru;
    client_max_body_size 200M;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_request_buffering off;

    include /etc/nginx/snippets/vpn-subscriptions.conf;
    include /etc/nginx/snippets/vpn-admin.conf;
    include /etc/nginx/snippets/vpn-user-pages.conf;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 127.0.0.1:7443 ssl; # internal HTTPS behind SNI stream
    ssl_certificate /etc/letsencrypt/live/neurosmmai.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/neurosmmai.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}
server {
    if ($host = www.neurosmmai.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = neurosmmai.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name neurosmmai.ru www.neurosmmai.ru;
    return 404; # managed by Certbot




}
