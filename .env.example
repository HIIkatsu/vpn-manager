# ==========================================
# VPN Manager v2 - Environment Configuration
# ==========================================

# Core FastAPI Settings
DEBUG=True
# Префикс для скрытия роутов/служебных ссылок, если используется в окружении.
SECRET_PREFIX=d87a8f94adf802aa6a0f7e35

# Database (PostgreSQL + asyncpg)
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://vpn_user:vpn_password@127.0.0.1:5433/vpn_db

# Telegram Bot (aiogram 3)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwXyZ
WEBHOOK_URL=https://example.com/webhook/telegram
WEBHOOK_URL_DOMAIN=example.com
# Секрет для проверки, что вебхук реально от Telegram.
WEBHOOK_SECRET=my-super-secret-telegram-token

# YooKassa Billing
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_XXXXXXXXXXXXXXXXXXXXXXX
# Optional webhook hardening. Set either an exact Authorization header or a shared secret header.
YOOKASSA_WEBHOOK_AUTH=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_WEBHOOK_IP_ALLOWLIST=
YOOKASSA_WEBHOOK_REQUIRE_API_VERIFY=True
TRUSTED_PROXY_IPS=127.0.0.1

# Remote Xray node sync
SYNC_NODES_TOKEN=replace-with-long-random-token
SYNC_NODES_IP_ALLOWLIST=132.243.194.119/32,194.50.94.177/32,150.251.152.174/32

# Infrastructure endpoints used by subscriptions, sync config, and audit
FINLAND_PUBLIC_IP=150.251.152.174
GERMANY_PUBLIC_IP=132.243.194.119
NETHERLANDS_PUBLIC_IP=194.50.94.177
RUSSIA_BALANCER_IP=132.243.230.173
XRAY_MAIN_PORT=443
XRAY_REDIRECT_PORT=20443
XRAY_RU_CLEAN_PORT=10444
XRAY_RU_WHITELIST_PORT=10445
XRAY_RU_CLEAN_SHORT_ID=45b6b57266629593
XRAY_RU_WHITELIST_SHORT_ID=45b6b57266629594

# Xray Core API (gRPC) and Reality/VLESS public subscription settings
XRAY_GRPC_HOST=127.0.0.1
XRAY_GRPC_PORT=10085
XRAY_REALITY_PRIVATE_KEY=replace-with-reality-private-key
VLESS_SNI=www.samsung.com
VLESS_PUBLIC_KEY=replace-with-reality-public-key
XRAY_REALITY_PUBLIC_KEY=replace-with-reality-public-key
VLESS_SHORT_ID=45b6b57266629592
VLESS_FINGERPRINT=chrome

# Admin Basic Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
